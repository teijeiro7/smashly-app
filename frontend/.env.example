# Supabase (required — both values visible in Supabase dashboard > Project Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Backend API URL (remove once Express backend is decommissioned in Phase 6)
VITE_API_URL=http://localhost:3000

# Google OAuth Client ID (Supabase handles OAuth now — keep for backward compat until fully migrated)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Set to 'true' to enable browser console output during development
VITE_DEBUG_CONSOLE=false
